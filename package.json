{
  "name": "madrasti-dashboard",
  "version": "4.0.0",
  "private": true,
  "description": "مدرستي — Multi-School SaaS Management Dashboard",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node scripts/start-standalone.mjs",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/auth-bff.test.mjs tests/school-admin.test.mjs tests/central-school-administrators.test.mjs tests/central-school-users.test.mjs tests/school-session-context.test.mjs tests/navigation-refactor.test.mjs tests/production-readiness.test.mjs",
    "test:auth": "node --test tests/auth-bff.test.mjs",
    "test:school-admin": "node --test tests/school-admin.test.mjs",
    "test:central-school-administrators": "node --test tests/central-school-administrators.test.mjs",
    "test:school-session-context": "node --test tests/school-session-context.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install chromium",
    "verify:backend": "node scripts/verify-backend-connectivity.mjs",
    "clean": "rimraf .next node_modules"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^14.2.21",
    "next-intl": "^3.26.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.7",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.21",
    "postcss": "^8.4.49",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3"
  }
}
