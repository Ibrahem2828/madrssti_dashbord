# Canonical backend origin. It is server-only and never imported by client code.
BACKEND_BASE_URL=https://api.example.com
# Legacy-compatible explicit API version. When omitted, it is derived safely as BACKEND_BASE_URL/api/v1.
API_BASE_URL=https://api.example.com/api/v1
NEXT_PUBLIC_APP_URL=https://dashboard.example.com
NEXT_PUBLIC_DEFAULT_LOCALE=ar
AUTH_COOKIE_SECURE=true
NODE_ENV=production
